{
  "name": "authwithmern",
  "module": "backend/index.ts",
  "type": "module",
  "scripts": {
    "backend": "nodemon --exec bun backend/index.js",
    "frontend": "cd frontend && vite",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "build": "cd frontend && vite build",
    "start": "NODE_ENV=production bun backend/index.js",
    "prod": "npm run build && npm run start"
  },
  "private": true,
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.3",
    "nodemon": "^3.1.11"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.1"
  }
}
